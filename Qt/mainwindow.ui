  <property name="styleSheet">
   <string notr="true">/* 全局暗黑背景 */
* {
    background-color: #1a1a1a;
    color: #ffffff;
}

/* 主窗口 + 中间面板 */
QMainWindow, QWidget#centralwidget {
    background-color: #1a1a1a;
    color: white;
}

/* 向导对话框（你现在看不清的那个） */
QWizard, QWizardPage {
    background-color: #1a1a1a;
    color: white;
}

/* 所有文字标签 */
QLabel {
    color: white;
}

/* 按钮样式 */
QPushButton {
    background-color: #333333;
    color: white;
    border: 1px solid #555555;
    padding: 6px 12px;
    border-radius: 4px;
}
QPushButton:hover {
    background-color: #444444;
}
QPushButton:pressed {
    background-color: #555555;
}

/* 输入框、文本框 */
QLineEdit, QTextEdit {
    background-color: #2a2a2a;
    color: white;
    border: 1px solid #555555;
    padding: 4px;
}

/* 菜单栏 */
QMenuBar {
    background-color: #222222;
    color: white;
}
QMenuBar::item:selected {
    background-color: #444444;
}

/* 菜单 */
QMenu {
    background-color: #2b2b2b;
    color: white;
}
QMenu::item:selected {
    background-color: #555555;
}

/* 滚动条 */
QScrollBar:vertical {
    background-color: #2a2a2a;
    width: 14px;
}
QScrollBar::handle:vertical {
    background-color: #666666;
    min-height: 20px;
}

/* 修正 Wizard 底部白色按钮栏 */
QWizard QDialogButtonBox, QWizard QPushButton#qt_wizard_finish, QWizard QPushButton#qt_wizard_cancel {
    background-color: #1a1a1a;
    color: white;
    border: 1px solid #555;
}
QWizard QDialogButtonBox {
    background-color: #1a1a1a;
}</string>
